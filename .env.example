# These values are n8n credential IDs/names, not API keys.
# Create the credentials in n8n first, then copy their IDs here before
# regenerating production-ready workflow exports.

THESIS_ARENA_OPENROUTER_CREDENTIAL_ID=
THESIS_ARENA_OPENROUTER_CREDENTIAL_NAME=OpenRouter account

THESIS_ARENA_POSTGRES_CREDENTIAL_ID=
THESIS_ARENA_POSTGRES_CREDENTIAL_NAME=PostgreSQL account

THESIS_ARENA_WEBHOOK_CREDENTIAL_ID=
THESIS_ARENA_WEBHOOK_CREDENTIAL_NAME=Thesis Arena Webhook Secret

THESIS_ARENA_N8N_API_CREDENTIAL_ID=
THESIS_ARENA_N8N_API_CREDENTIAL_NAME=Thesis Arena n8n API Client

# Set this after importing the main analysis workflow.
THESIS_ARENA_ANALYSIS_WORKFLOW_ID=
